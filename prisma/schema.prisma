datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model NovelProject {
  id               String         @id
  userId           String         @default("default_user")
  title            String
  description      String
  styleSetting     String
  worldSetting     String
  powerSystem      String         @default("")
  goldFinger       String         @default("")
  coreConflict     String         @default("")
  factionsMap      String         @default("")
  sellingPoints    String         @default("")
  skillSystem      String         @default("")
  location         String         @default("")
  faction          String         @default("")
  currency         String         @default("")
  item             String         @default("")
  outlineFull      String         @default("")
  rollingSynopsis  String         @default("")
  antiAiStyleRules String         @default("[]")
  modelsConfig     String         @default("[]")
  agentBindings    String         @default("{}")
  agentOverrides   String         @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  characters       Character[]
  worldRules       WorldRule[]
  worldStates      WorldState[]
  chapters         Chapter[]
  agentMessages    AgentMessage[]
  versionSnapshots VersionSnapshot[]
}

model Character {
  id            String       @id
  projectId     String
  project       NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  role          String
  age           String
  identity      String
  personality   String       @default("[]")
  goals         String       @default("[]")
  relationships String       @default("[]")
  currentState  String
  forbidden     String       @default("[]")
}

model WorldRule {
  id          String       @id
  projectId   String
  project     NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  name        String
  description String
}

model WorldState {
  id               String       @id
  projectId        String
  project          NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category         String
  name             String
  content          String
  pinned           Boolean      @default(false)
  source           String       @default("ai")
  updatedAtChapter String       @default("")
  updatedAt        DateTime     @updatedAt
}

model Chapter {
  id                    String       @id
  projectId             String
  project               NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  content               String       @default("")
  summary               String       @default("")
  characterChanges      String       @default("[]")
  newForeshadowing      String       @default("[]")
  resolvedForeshadowing String       @default("[]")
  timelineEvents        String       @default("[]")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model AgentMessage {
  id        String       @id
  projectId String
  project   NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String       @default("default_user")
  type      String
  agent     String?
  label     String?
  content   String
  toolName  String?
  toolInput String?
  from      String?
  fromLabel String?
  to        String?
  toLabel   String?
  createdAt DateTime     @default(now())
}

model VersionSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   NovelProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // outline | macro | chapter | character | worldRule
  key       String   // 具体标识：如 "outlineFull", "macro", chapterId, characterId, worldRuleId
  label     String   // 人类可读标签：如 "分卷主线大纲", "世界观设定", "第一章 xxx"
  data      String   // JSON 序列化的快照内容
  source    String   @default("manual") // manual | auto | ai
  createdAt DateTime @default(now())
}
